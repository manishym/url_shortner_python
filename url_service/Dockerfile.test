# Run tests with same Python as production. No Kafka/Redis/Postgres required (mocked).
FROM python:3.12-slim
WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY requirements-dev.txt .
RUN pip install --no-cache-dir -r requirements-dev.txt
COPY main.py conftest.py pytest.ini .coveragerc ./
COPY static/ static/
COPY tests/ tests/
ENV PYTHONUNBUFFERED=1
CMD ["python", "-m", "pytest", "tests/", "-v", "--cov=main", "--cov-report=term-missing", "--cov-fail-under=85"]
